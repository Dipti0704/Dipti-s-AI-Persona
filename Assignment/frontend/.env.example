# =========================================================================
# FRONTEND VITE ENVIRONMENT VARIABLES CONFIGURATION (Vite Client)
# =========================================================================

# 🚀 FastAPI Backend Server URL
# In local development: http://localhost:8000
# In production (e.g. Render/Railway): https://your-backend-name.onrender.com
VITE_BACKEND_URL=http://localhost:8000

# 🎙️ Vapi Web Integration credentials
# Retrieve your Public Key from Vapi Dashboard -> Account -> Keys
VITE_VAPI_PUBLIC_KEY=your_vapi_public_key_here
# Retrieve your Assistant ID from Vapi Dashboard -> Assistants
VITE_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
