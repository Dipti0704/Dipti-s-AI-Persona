# URL of the FastAPI backend (e.g., https://your-backend.onrender.com or http://localhost:8000)
VITE_BACKEND_URL=http://localhost:8000

# Vapi voice AI public key (found in Vapi dashboard -> keys)
VITE_VAPI_PUBLIC_KEY=your_vapi_public_key_here

# Vapi voice assistant ID (found in Vapi dashboard -> assistants)
VITE_VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
