# =========================================================================
# BACKEND ENVIRONMENT VARIABLES CONFIGURATION (app/config.py)
# =========================================================================

# 🧠 OpenAI API Configuration (Required for online RAG & LLM Agent)
# Get a key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# 🌲 Pinecone Vector DB Configuration (Optional - falls back to Local RAG)
# Get a key and index from: https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=resumes-index
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# 📅 Cal.com Scheduling Configuration (Optional - falls back to local bookings.json)
# Create a free account at https://cal.com and get your API key under Settings -> Developer API
CAL_API_KEY=your_cal_com_api_key_here
# Get the Event Type ID for your booking type (e.g. 15-minute chat) from Cal.com Dashboard -> Event Types
CAL_EVENT_TYPE_ID=your_event_type_id_here

# 🚀 Server Port & Host Configuration
PORT=8000
HOST=0.0.0.0
