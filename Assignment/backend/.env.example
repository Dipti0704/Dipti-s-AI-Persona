# OpenAI API key used for the chat representative (starts with sk-...)
OPENAI_API_KEY=your_openai_api_key_here

# Cal.com API key for booking interviews (starts with cal_live_...)
CAL_API_KEY=your_cal_api_key_here

# Cal.com Event Type ID to link the booking calendar slots
CAL_EVENT_TYPE_ID=your_cal_event_type_id_here

# Local file database fallback path (used if Cal.com credentials are not provided)
LOCAL_BOOKINGS_PATH=data/bookings.json
